
@namespace("ru.practicum.ewm.stats.avro")

protocol UserActionsProtocol {
	record UserActionAvro {
		long userId;
		long eventId;
		ActionTypeAvro actionType;
		timestamp_ms timestamp;
	}

	enum ActionTypeAvro {
		VIEW, // просмотр мероприятия
		REGISTER, //регистрация на мероприятие
		LIKE // лайк мероприятия
	}
}